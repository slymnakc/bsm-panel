# ─────────────────────────────────────────────────────────────
# BSM Panel — Environment Variables
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# ─────────────────────────────────────────────────────────────

# ── Sunucu ──────────────────────────────────────────────────
PORT=3000

# ── Supabase ────────────────────────────────────────────────
# Supabase proje URL'i ve publishable (anon) key.
# Supabase Dashboard → Settings → API'dan alın.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (Resend) ───────────────────────────────────────────
# https://resend.com/api-keys adresinden oluşturun.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Resend'de doğrulanmış domain ile gönderici adresi:
MAIL_FROM=BSM Panel <noreply@yourdomain.com>

# ── Güvenlik ────────────────────────────────────────────────
# Üretimde sitenin tam origin'ini girin (protokol + host).
# Birden fazla için virgülle ayırın.
# Boş bırakılırsa same-origin kontrolü aktif kalır.
# Örnek: https://bsm.yourdomain.com
ALLOWED_ORIGINS=

# ── Rate Limiting ───────────────────────────────────────────
# Email endpoint: saatte maksimum istek sayısı (varsayılan 10)
RATE_LIMIT_EMAIL_MAX=10
# PDF endpoint: saatte maksimum istek sayısı (varsayılan 30)
RATE_LIMIT_PDF_MAX=30
