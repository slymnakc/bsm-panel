{
  "name": "bsm-panel",
  "version": "1.5.7",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "test:e2e": "playwright test --config=playwright.config.js",
    "test:smoke": "playwright test tests/e2e/00-smoke.spec.js tests/e2e/01-navigation.spec.js",
    "test:e2e:headed": "playwright test --headed --config=playwright.config.js",
    "test:report": "playwright show-report tests/_report"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "playwright": "^1.59.1",
    "@playwright/test": "^1.59.1"
  }
}
